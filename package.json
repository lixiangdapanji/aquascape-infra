{
  "name": "@aquascape/infra",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "cdk": "cdk",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "test": "jest --passWithNoTests"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/test"],
    "testMatch": ["**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": { "strictNullChecks": false } }]
    }
  },
  "dependencies": {
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.0",
    "aws-cdk": "^2.160.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
